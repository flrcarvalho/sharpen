# Planilhador — variáveis de ambiente (EXEMPLO)
# Copie para `.env` e preencha. NUNCA versione o `.env` real (já está no .gitignore).
# Em produção, os valores vivem nas env vars do Railway, não em arquivo.

# Chave da API Anthropic (extração por IA). Formato: sk-ant-...
ANTHROPIC_API_KEY=sk-ant-cole-sua-chave-aqui

# String de conexão Postgres. Em produção use a do Railway.
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://usuario:senha@host:porta/banco

# Segredo de assinatura do cookie de sessão (HMAC). Gere um valor aleatório longo
# (ex.: `python -c "import secrets; print(secrets.token_hex(32))"`). Se ausente, o
# app gera um efêmero no boot (fail-closed) e as sessões caem a cada reinício —
# defina em produção para persistir os logins.
SESSION_SECRET=

# Hashes bcrypt das senhas dos usuários (um por usuário). SEM default no código:
# se faltar, o login daquele usuário falha (fail-closed). Gere com bcrypt.
SENHA_FECA_HASH=
SENHA_DIOGO_HASH=
SENHA_LAVA_HASH=
