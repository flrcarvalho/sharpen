{
  "manifest_version": 3,
  "name": "SharpenUp",
  "version": "0.2.8",
  "description": "A perninha do Sharpen: captura seus bilhetes na casa e sobe pro painel do sharpen.bet via pareamento por código.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "SharpenUp"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://*.superbet.bet.br/*", "*://superbet.bet.br/*", "*://*.superbet.com/*"],
      "js": ["sb_inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.betesporte.bet.br/*", "*://betesporte.bet.br/*"],
      "js": ["be_inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.betano.bet.br/*", "*://betano.bet.br/*"],
      "js": ["bn_inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
