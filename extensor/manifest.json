{
  "manifest_version": 3,
  "name": "Sharpen Capture",
  "version": "0.1.0",
  "description": "Captura bilhetes das casas (print) e envia para o sharpen.bet via pareamento por código. Funciona em qualquer Chromium (Octo, Chrome, Edge, Brave).",
  "default_locale": "pt_BR",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sharpen Capture"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.sharpen.bet/*",
    "https://sharpen.bet/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
